// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserRole {
  UNASSIGNED
  INTERVIEWEE
  INTERVIEWER
}

enum BookingStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  REJECTED
}

enum SettlementStatus {
  HELD
  SETTLED
  REFUNDED
  DISPUTED
}

enum AttendanceEvent {
  JOINED
  LEFT
  REJOINED
  DISCONNECTED
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum PayoutStatus {
  PROCESSING
  PROCESSED
}

enum InterviewCategory {
  FRONTEND
  BACKEND
  FULLSTACK
  DSA
  SYSTEM_DESIGN
  BEHAVIORAL
  DEVOPS
  MOBILE
}

enum FeedbackRating {
  POOR
  AVERAGE
  GOOD
  EXCELLENT
}

enum TransactionType {
  CREDIT_PURCHASE
  BOOKING_DEDUCTION
  BOOKING_EARNING
  BOOKING_REFUND
  BOOKING_HELD
  HELD_RELEASE
  ADMIN_ADJUSTMENT
  REFERRAL_REWARD
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  FRAUDULENT
}

enum AISummaryStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── USER ────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  imageUrl    String?
  role        UserRole @default(UNASSIGNED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // interviewee-only
  credits                Int       @default(0)
  currentPlan            String    @default("free")
  creditsLastAllocatedAt DateTime?

  // interviewer-only
  bio           String?
  title         String?
  company       String?
  yearsExp      Int?
  categories    InterviewCategory[]
  creditRate    Int                 @default(1)
  creditBalance Int                 @default(0)

  // rating (interviewer-only, denormalized for performance)
  avgRating      Float?
  totalReviews   Int     @default(0)
  completionRate Float?
  noShowCount    Int     @default(0)

  // referral
  referralCode String? @unique
  referredById String?

  // AI consent
  aiReviewConsent Boolean @default(false)

  // ─── relations ──────────────────────────────────────
  availabilities        Availability[]
  bookingsAsInterviewee Booking[]            @relation("IntervieweeBookings")
  bookingsAsInterviewer Booking[]            @relation("InterviewerBookings")
  transactions          CreditTransaction[]
  payouts               Payout[]
  attendanceLogs        AttendanceLog[]
  reviewsReceived       InterviewerReview[]  @relation("ReviewsReceived")
  reviewsGiven          InterviewerReview[]  @relation("ReviewsGiven")
  badges                UserBadge[]

  referralsSent         Referral[]           @relation("ReferralsSent")
  referralsReceived     Referral[]           @relation("ReferralsReceived")
}

// ─── AVAILABILITY ────────────────────────────────────────

model Availability {
  id            String             @id @default(uuid())
  interviewerId String
  interviewer   User               @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  startTime     DateTime
  endTime       DateTime
  status        AvailabilityStatus @default(AVAILABLE)

  @@index([interviewerId, startTime])
}

// ─── BOOKINGS ────────────────────────────────────────────

model Booking {
  id             String        @id @default(uuid())
  intervieweeId  String
  interviewee    User          @relation("IntervieweeBookings", fields: [intervieweeId], references: [id])
  interviewerId  String
  interviewer    User          @relation("InterviewerBookings", fields: [interviewerId], references: [id])
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus @default(PENDING)
  creditsCharged Int
  streamCallId   String?       @unique
  recordingUrl   String?

  // settlement
  settlementStatus  SettlementStatus @default(HELD)
  heldAmount        Int              @default(0)
  settledAt         DateTime?
  settlementNote    String?

  // attendance tracking
  interviewerJoined  Boolean @default(false)
  intervieweeJoined  Boolean @default(false)
  interviewerDuration Int    @default(0) // seconds
  intervieweeDuration Int    @default(0) // seconds



  // ─── relations ──────────────────────────────────────
  feedback       Feedback?
  review         InterviewerReview?
  aiSummary      AISummary?
  attendanceLogs AttendanceLog[]
  transactions   CreditTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([interviewerId, status])
  @@index([intervieweeId, status])
  @@index([settlementStatus])
}

// ─── ATTENDANCE LOGS ─────────────────────────────────────

model AttendanceLog {
  id        String          @id @default(uuid())
  bookingId String
  booking   Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  event     AttendanceEvent
  timestamp DateTime        @default(now())
  metadata  Json?

  @@index([bookingId, userId])
}

// ─── FEEDBACK (AI-generated post-call) ───────────────────

model Feedback {
  id             String         @id @default(uuid())
  bookingId      String         @unique
  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  summary        String         @db.Text
  technical      String         @db.Text
  communication  String         @db.Text
  problemSolving String         @db.Text
  recommendation String
  strengths      String[]
  improvements   String[]
  overallRating  FeedbackRating
  sessionRating  Int?
  sessionComment String?        @db.Text
  createdAt      DateTime       @default(now())
}

// ─── INTERVIEWER REVIEWS (by interviewee) ────────────────

model InterviewerReview {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  interviewerId String
  interviewer   User     @relation("ReviewsReceived", fields: [interviewerId], references: [id])
  intervieweeId String
  interviewee   User     @relation("ReviewsGiven", fields: [intervieweeId], references: [id])

  rating  Int       // 1-5 stars
  comment String?   @db.Text
  tags    String[]  // ["knowledgeable", "patient", "clear-explanations"]

  createdAt DateTime @default(now())

  @@index([interviewerId, createdAt])
}

// ─── BADGES ──────────────────────────────────────────────

model Badge {
  id          String      @id @default(uuid())
  slug        String      @unique
  name        String
  description String
  icon        String
  category    String      // "achievement", "expertise", "performance"
  criteria    Json        // { type: "min_sessions", value: 50 }
  createdAt   DateTime    @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}



// ─── REFERRALS ───────────────────────────────────────────

model Referral {
  id             String         @id @default(uuid())
  referrerId     String
  referrer       User           @relation("ReferralsSent", fields: [referrerId], references: [id])
  refereeId      String         @unique
  referee        User           @relation("ReferralsReceived", fields: [refereeId], references: [id])

  status         ReferralStatus @default(PENDING)
  referrerReward Int            @default(2)
  refereeReward  Int            @default(1)
  rewardedAt     DateTime?
  createdAt      DateTime       @default(now())

  @@index([referrerId])
}

// ─── AI SUMMARY (genuine post-call analysis) ─────────────

model AISummary {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // scores (1-100)
  overallScore       Int?
  technicalScore     Int?
  communicationScore Int?
  problemSolvingScore Int?
  confidenceScore    Int?

  // detailed feedback
  technicalFeedback     String?  @db.Text
  communicationFeedback String?  @db.Text
  strengthsShown        String[]
  weakAreas             String[]
  missedConcepts        String[]
  suggestedTopics       String[]
  improvementRoadmap    String?  @db.Text
  readinessLevel        String?

  // source data
  transcriptUrl  String?
  recordingUrl   String?
  interviewType  String?

  // consent
  consentGiven Boolean @default(false)

  // processing
  status       AISummaryStatus @default(PENDING)
  processedAt  DateTime?
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([status])
}

// ─── CREDIT TRANSACTIONS ─────────────────────────────────

model CreditTransaction {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  type      TransactionType
  bookingId String?
  booking   Booking?        @relation(fields: [bookingId], references: [id])
  createdAt DateTime        @default(now())
}

// ─── PAYOUTS ─────────────────────────────────────────────

model Payout {
  id            String       @id @default(uuid())
  interviewerId String
  interviewer   User         @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  credits       Int
  platformFee   Float
  netAmount     Float
  paymentMethod String
  paymentDetail String
  status        PayoutStatus @default(PROCESSING)
  adminNote     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  processedAt   DateTime?
  processedBy   String?

  @@index([status, createdAt])
  @@index([interviewerId, status])
}
